import "pkg:/source/api/sdk.bs"
import "pkg:/source/enums/ColorPalette.bs"
import "pkg:/source/enums/KeyCode.bs"
import "pkg:/source/enums/PlaybackMethod.bs"
import "pkg:/source/enums/SettingType.bs"
import "pkg:/source/enums/String.bs"
import "pkg:/source/utils/config.bs"
import "pkg:/source/utils/deviceCapabilities.bs"
import "pkg:/source/utils/JellyseerrUtils.bs"
import "pkg:/source/utils/misc.bs"
import "pkg:/source/utils/settingsSync.bs"

const HOME_ROWS_HSS_LOCAL_SETTING = "ui.home.hssRowsLocalConfig"
const HOME_ROWS_KT_LOCAL_SETTING = "ui.home.ktRowsLocalConfig"

sub init()
    m.top.optionsAvailable = false

    m.showSecretMenu = false
    m.keypresses = []
    m.magicKeyPressSequence = [KeyCode.UP, KeyCode.LEFT, KeyCode.REPLAY, KeyCode.REWIND, KeyCode.UP, KeyCode.LEFT, KeyCode.REPLAY, KeyCode.REWIND]

    m.userLocation = []

    m.settingsMenu = m.top.findNode("settingsMenu")
    'm.settingsMenu.focusBitmapBlendColor = chainLookupReturn(m.global.session, "user.settings.colorCursor", ColorPalette.HIGHLIGHT)
    m.settingsMenu.focusFootprintBlendColor = ColorPalette.TRANSPARENT

    m.settingDesc = m.top.findNode("settingDesc")
    m.path = m.top.findNode("path")

    m.version = m.top.findNode("version")
    drawingStyles = {
        "default": {
            "fontSize": 27,
            "fontUri": "font:SystemFontFile",
            "color": "#EFEFEFFF"
        },
        "b": {
            "fontSize": 27,
            "fontUri": "font:SystemFontFile",
            "color": chainLookupReturn(m.global.session, "user.settings.colorCursor", ColorPalette.HIGHLIGHT)
        }
    }

    if isValid(m.version)
        m.version.drawingStyles = drawingStyles
        m.version.text = `${LCase(m.global.app.name)} ${m.global.app.version} - ${tr("What's New")}?`
    end if

    m.boolSetting = m.top.findNode("boolSetting")
    m.integerSetting = m.top.findNode("integerSetting")
    m.colorgrid = m.top.findNode("colorgrid")
    m.slider = m.top.findNode("slider")

    m.radioSetting = m.top.findNode("radioSetting")
    m.radioSetting.focusBitmapBlendColor = chainLookupReturn(m.global.session, "user.settings.colorCursor", ColorPalette.HIGHLIGHT)
    m.radioSetting.focusFootprintBlendColor = ColorPalette.TRANSPARENT
    m.radioSetting.focusedColor = ColorPalette.WHITE

    m.integerSetting.observeField("submit", "onKeyGridSubmit")
    m.integerSetting.observeField("escape", "onKeyGridEscape")

    m.settingsMenu.setFocus(true)
    m.settingsMenu.observeField("itemFocused", "settingFocused")
    m.settingsMenu.observeField("itemSelected", "settingSelected")

    m.boolSetting.observeField("checkedItem", "boolSettingChanged")
    m.radioSetting.observeField("checkedItem", "radioSettingChanged")
    m.colorgrid.observeField("itemSelected", "onColorSelected")
    m.slider.observeField("value", "onSliderSelected")

    m.postTask = createObject("roSGNode", "PostTask")

    m.keypressTimer = m.top.findNode("keypressTimer")
    m.keypressTimer.observeField("fire", "onKeypressTimerFire")

    m.currentStringSetting = invalid
    m.stringInputDialog = invalid
    m.mediaBarSelectorSettingName = invalid
    m.mediaBarSelectorDialogOptions = []
    m.mediaBarPickerTask = invalid
    m.pendingMediaBarSettingItem = invalid
    m.hssDetected = invalid
    m.hssProbeTask = invalid
    m.ktDetected = invalid
    m.ktProbeTask = invalid
    m.homeRowsSourceTask = invalid
    m.pendingPluginRowsSetting = invalid
    m.pendingPluginRowsSource = ""
    m.pluginRowsDialogSource = ""
    m.pluginRowsDialogSettingKey = ""
    m.pluginRowsDialogOptions = []
    m.pluginRowsDialogOptionMap = {}
    m.pluginRowsDialogSettingItem = invalid

    m.seerrKeyboardMode = ""
    m.seerrTempUsername = ""
    m.seerrAccountSection = invalid
    m.seerrAuthTask = invalid
    m.seerrLogoutTask = invalid

    m.configTree = reorderSettingsForFlutter(GetConfigTree())
    updateHssSettingGate()
    updateKtSettingGate()
    LoadMenu({ children: m.configTree })
    refreshHssPluginDetection()
    refreshKtPluginDetection()
end sub

sub onKeypressTimerFire()
    m.keypresses.clear()
end sub

sub hideEditingControls()
    m.settingDesc.visible = false
    m.boolSetting.visible = false
    m.integerSetting.visible = false
    m.radioSetting.visible = false
    m.colorgrid.visible = false
    m.slider.visible = false
end sub

function getFocusedSetting() as dynamic
    focusIndex = m.settingsMenu.itemFocused
    if focusIndex < 0 then return invalid

    if isValid(m.visibleItemsMap) and focusIndex < m.visibleItemsMap.Count()
        return m.visibleItemsMap[focusIndex]
    end if

    if m.userLocation.Count() > 0 and isValid(m.userLocation.peek().children) and focusIndex < m.userLocation.peek().children.Count()
        return m.userLocation.peek().children[focusIndex]
    end if

    return invalid
end function

function dynamicToDisplayString(value as dynamic) as string
    if not isValid(value) then return ""

    valueType = type(value)
    if isStringEqual(valueType, "Boolean") or isStringEqual(valueType, "roBoolean")
        if value then return "true"
        return "false"
    end if

    return value.ToStr()
end function

function isMediaBarMultiSelectSetting(settingName as dynamic) as boolean
    if not isValid(settingName) then return false
    if isStringEqual(settingName, "ui.home.mediaBarLibraryIds") then return true
    if isStringEqual(settingName, "ui.home.mediaBarCollectionIds") then return true
    if isStringEqual(settingName, "ui.home.mediaBarExcludedGenres") then return true
    return false
end function

function parseStringArraySetting(value as dynamic) as object
    if not isValid(value) then return []

    valueType = type(value)
    if valueType = "roArray" or valueType = "Array"
        result = []
        for each item in value
            if isValid(item)
                result.push(item.toStr())
            end if
        end for
        return result
    end if

    parsed = ParseJson(value.toStr())
    if type(parsed) = "roArray" or type(parsed) = "Array"
        result = []
        for each item in parsed
            if isValid(item)
                result.push(item.toStr())
            end if
        end for
        return result
    end if

    return []
end function

function isStringInArray(value as string, values as object) as boolean
    if not isValid(values) then return false
    for each item in values
        if isStringEqual(item.toStr(), value)
            return true
        end if
    end for
    return false
end function

function getMediaBarSelectorSummary(settingName as string, currentValue as dynamic) as string
    selectedIds = parseStringArraySetting(currentValue)
    selectedCount = selectedIds.Count()

    if isStringEqual(settingName, "ui.home.mediaBarLibraryIds")
        if selectedCount = 0 then return tr("All Libraries")
        return `${selectedCount.toStr()} ${tr("selected")}`
    end if

    if isStringEqual(settingName, "ui.home.mediaBarCollectionIds")
        if selectedCount = 0 then return tr("All Collections/Playlists")
        return `${selectedCount.toStr()} ${tr("selected")}`
    end if

    if selectedCount = 0 then return tr("None")
    return `${selectedCount.toStr()} ${tr("excluded")}`
end function

sub loadMediaBarPickerOptions(settingItem as object)
    if not isValid(settingItem) then return

    if isValid(m.mediaBarPickerTask)
        m.mediaBarPickerTask.unobserveFieldScoped("options")
        m.mediaBarPickerTask.unobserveFieldScoped("errorMessage")
    end if

    contentType = get_user_setting("ui.home.mediaBarContentType")
    if not isValidAndNotEmpty(contentType)
        contentType = "both"
    end if

    m.pendingMediaBarSettingItem = settingItem
    m.mediaBarPickerTask = createObject("roSGNode", "MediaBarPickerOptionsTask")
    m.mediaBarPickerTask.userId = m.global.session.user.id
    m.mediaBarPickerTask.settingName = settingItem.settingName
    m.mediaBarPickerTask.contentType = contentType
    m.mediaBarPickerTask.observeFieldScoped("options", "onMediaBarPickerOptionsLoaded")
    m.mediaBarPickerTask.observeFieldScoped("errorMessage", "onMediaBarPickerOptionsError")
    m.mediaBarPickerTask.control = "RUN"
end sub

sub onMediaBarPickerOptionsLoaded(event as object)
    options = event.getData()

    if not isValid(m.pendingMediaBarSettingItem)
        clearMediaBarPickerTask()
        return
    end if

    showMediaBarSelectorDialog(m.pendingMediaBarSettingItem, options)
    clearMediaBarPickerTask()
end sub

sub onMediaBarPickerOptionsError(event as object)
    err = dynamicToDisplayString(event.getData())
    if isValidAndNotEmpty(err)
        ShowToast(err, "error")
        m.settingsMenu.setFocus(true)
    end if
    clearMediaBarPickerTask()
end sub

sub clearMediaBarPickerTask(clearPending = true as boolean)
    if isValid(m.mediaBarPickerTask)
        m.mediaBarPickerTask.unobserveFieldScoped("options")
        m.mediaBarPickerTask.unobserveFieldScoped("errorMessage")
    end if

    m.mediaBarPickerTask = invalid
    if clearPending
        m.pendingMediaBarSettingItem = invalid
    end if
end sub

sub showMediaBarSelectorDialog(settingItem as object, options as object)
    if not isValidAndNotEmpty(options)
        ShowToast("No options available for this setting right now.", "error")
        m.settingsMenu.setFocus(true)
        return
    end if

    storedValue = get_user_setting(settingItem.settingName)
    if not isValid(storedValue)
        storedValue = chainLookupReturn(m.global.session, `user.settings.${settingItem.settingName}`, "[]")
    end if
    selectedIds = parseStringArraySetting(storedValue)

    dialog = createObject("roSGNode", "MediaBarChecklistDialog")
    dlgPalette = createObject("roSGNode", "RSGPalette")
    dlgPalette.colors = {
        DialogBackgroundColor: chainLookupReturn(m.global.session, "user.settings.colorDialogBackground", ColorPalette.ELEMENTBACKGROUND),
        DialogFocusColor: chainLookupReturn(m.global.session, "user.settings.colorCursor", ColorPalette.HIGHLIGHT),
        DialogFocusItemColor: chainLookupReturn(m.global.session, "user.settings.colorDialogSelectedText", ColorPalette.WHITE),
        DialogTextColor: chainLookupReturn(m.global.session, "user.settings.colorDialogText", ColorPalette.WHITE)
    }
    dialog.palette = dlgPalette
    dialog.title = tr(settingItem.title)
    dialog.buttons = [tr("Save"), tr("Cancel")]
    dialog.observeField("buttonSelected", "onMediaBarSelectorDialogButton")

    checklist = dialog.findNode("checklist")
    checklistContent = createObject("roSGNode", "ContentNode")
    checkedState = []

    for each option in options
        listItem = checklistContent.CreateChild("ContentNode")
        listItem.title = option.title
        checkedState.push(isStringInArray(option.id, selectedIds))
    end for

    checklist.content = checklistContent
    checklist.checkedState = checkedState

    m.mediaBarSelectorSettingName = settingItem.settingName
    m.mediaBarSelectorDialogOptions = options
    m.top.getScene().dialog = dialog
end sub

sub onMediaBarSelectorDialogButton(event as object)
    dialog = event.getRoSGNode()
    buttonIndex = dialog.buttonSelected

    if buttonIndex = 0 and isValidAndNotEmpty(m.mediaBarSelectorSettingName)
        checklist = dialog.findNode("checklist")
        checkedState = []
        if isValid(checklist)
            checkedState = checklist.checkedState
        end if

        selectedIds = []
        for i = 0 to m.mediaBarSelectorDialogOptions.Count() - 1
            if i < checkedState.Count() and checkedState[i]
                selectedIds.push(m.mediaBarSelectorDialogOptions[i].id)
            end if
        end for

        serialized = FormatJson(selectedIds)
        set_user_setting(m.mediaBarSelectorSettingName, serialized)
        syncSettingToServer(m.mediaBarSelectorSettingName, serialized)
        refreshCurrentItemValue()
    end if

    dialog.close = true
    m.mediaBarSelectorSettingName = invalid
    m.mediaBarSelectorDialogOptions = []
    hideEditingControls()
    m.settingsMenu.setFocus(true)
end sub

sub openPluginRowsManager(settingItem as object)
    sourceName = getPluginRowsManagerSource(chainLookupReturn(settingItem, "settingName", ""))
    if not isValidAndNotEmpty(sourceName)
        ShowToast("Unsupported row manager.", "error")
        m.settingsMenu.setFocus(true)
        return
    end if

    if isValid(m.homeRowsSourceTask)
        clearHomeRowsSourceTask()
    end if

    m.pendingPluginRowsSetting = settingItem
    m.pendingPluginRowsSource = sourceName

    m.homeRowsSourceTask = createObject("roSGNode", "HomeRowsSourceRowsTask")
    m.homeRowsSourceTask.serverUrl = chainLookupReturn(m.global, "session.server.url", "")
    m.homeRowsSourceTask.userId = chainLookupReturn(m.global, "session.user.id", "")
    m.homeRowsSourceTask.authToken = chainLookupReturn(m.global, "session.user.authToken", "")
    m.homeRowsSourceTask.source = sourceName
    m.homeRowsSourceTask.observeFieldScoped("rows", "onHomeRowsSourceRowsLoaded")
    m.homeRowsSourceTask.observeFieldScoped("errorMessage", "onHomeRowsSourceRowsError")
    m.homeRowsSourceTask.control = "RUN"
end sub

sub onHomeRowsSourceRowsLoaded(event as object)
    rows = event.getData()

    if not isValid(m.pendingPluginRowsSetting)
        clearHomeRowsSourceTask()
        return
    end if

    pendingSetting = m.pendingPluginRowsSetting
    pendingSource = m.pendingPluginRowsSource
    clearHomeRowsSourceTask()
    showPluginRowsManagerDialog(pendingSetting, pendingSource, rows)
end sub

sub onHomeRowsSourceRowsError(event as object)
    err = dynamicToDisplayString(event.getData())
    if isValidAndNotEmpty(err)
        ShowToast(err, "error")
        m.settingsMenu.setFocus(true)
    end if
    clearHomeRowsSourceTask()
end sub

sub clearHomeRowsSourceTask(clearPending = true as boolean)
    if isValid(m.homeRowsSourceTask)
        m.homeRowsSourceTask.unobserveFieldScoped("rows")
        m.homeRowsSourceTask.unobserveFieldScoped("errorMessage")
    end if

    m.homeRowsSourceTask = invalid

    if clearPending
        m.pendingPluginRowsSetting = invalid
        m.pendingPluginRowsSource = ""
    end if
end sub

sub showPluginRowsManagerDialog(settingItem as object, sourceName as string, rows as dynamic)
    if type(rows) <> "Array" and type(rows) <> "roArray"
        rows = []
    end if

    normalizedRows = []
    for each row in rows
        rowId = dynamicToDisplayString(chainLookupReturn(row, "id", "")).Trim()
        if not isValidAndNotEmpty(rowId)
            continue for
        end if

        rowTitle = dynamicToDisplayString(chainLookupReturn(row, "title", rowId)).Trim()
        if not isValidAndNotEmpty(rowTitle)
            rowTitle = rowId
        end if

        normalizedRows.push({
            id: rowId,
            title: rowTitle,
            source: normalizeHomeRowsSourceName(chainLookupReturn(row, "source", sourceName)),
            kind: dynamicToDisplayString(chainLookupReturn(row, "kind", "")),
            route: dynamicToDisplayString(chainLookupReturn(row, "route", "")),
            additionalData: chainLookupReturn(row, "additionalData", invalid),
            enabled: normalizeBoolSettingValue(chainLookupReturn(row, "enabled", true)),
            order: parseIntSettingValue(chainLookupReturn(row, "order", normalizedRows.Count()), normalizedRows.Count())
        })
    end for

    if normalizedRows.Count() = 0
        ShowToast("No rows available for this source.", "error")
        m.settingsMenu.setFocus(true)
        return
    end if

    settingKey = getPluginRowsManagerStorageKey(sourceName)
    savedRows = parsePluginRowsConfigValue(getUserSettingValue(settingKey, "[]"))
    savedMap = buildPluginRowsConfigMap(savedRows)

    sortedRows = []
    for each row in normalizedRows
        mapKey = LCase(dynamicToDisplayString(chainLookupReturn(row, "id", "")).Trim())
        rowOrder = parseIntSettingValue(chainLookupReturn(row, "order", sortedRows.Count()), sortedRows.Count())
        if savedMap.DoesExist(mapKey)
            rowOrder = parseIntSettingValue(chainLookupReturn(savedMap[mapKey], "order", rowOrder), rowOrder)
        end if

        row.order = rowOrder

        inserted = false
        for i = 0 to sortedRows.Count() - 1
            if rowOrder < parseIntSettingValue(chainLookupReturn(sortedRows[i], "order", i), i)
                sortedRows.Insert(i, row)
                inserted = true
                exit for
            end if
        end for

        if not inserted
            sortedRows.push(row)
        end if
    end for

    dialog = createObject("roSGNode", "MediaBarChecklistDialog")
    dlgPalette = createObject("roSGNode", "RSGPalette")
    dlgPalette.colors = {
        DialogBackgroundColor: chainLookupReturn(m.global.session, "user.settings.colorDialogBackground", ColorPalette.ELEMENTBACKGROUND),
        DialogFocusColor: chainLookupReturn(m.global.session, "user.settings.colorCursor", ColorPalette.HIGHLIGHT),
        DialogFocusItemColor: chainLookupReturn(m.global.session, "user.settings.colorDialogSelectedText", ColorPalette.WHITE),
        DialogTextColor: chainLookupReturn(m.global.session, "user.settings.colorDialogText", ColorPalette.WHITE)
    }
    dialog.palette = dlgPalette

    if isStringEqual(normalizeHomeRowsSourceName(sourceName), "hss")
        dialog.title = tr("Manage HSS Rows")
    else
        dialog.title = tr("Manage KefinTweaks Rows")
    end if
    dialog.message = [tr("Use Rewind/Fast-Forward to reorder rows. Press OK to toggle each row.")]

    dialog.allowReorder = true

    dialog.buttons = [tr("Save"), tr("Cancel")]
    dialog.observeField("buttonSelected", "onPluginRowsManagerDialogButton")

    checklist = dialog.findNode("checklist")
    checklistContent = createObject("roSGNode", "ContentNode")
    checkedState = []
    optionMap = {}

    for each row in sortedRows
        listItem = checklistContent.CreateChild("ContentNode")
        listItem.id = row.id
        listItem.title = row.title

        mapKey = LCase(dynamicToDisplayString(chainLookupReturn(row, "id", "")).Trim())
        rowEnabled = normalizeBoolSettingValue(chainLookupReturn(row, "enabled", true))
        if savedMap.DoesExist(mapKey)
            rowEnabled = normalizeBoolSettingValue(chainLookupReturn(savedMap[mapKey], "enabled", rowEnabled))
        end if

        optionMap[mapKey] = row

        checkedState.push(rowEnabled)
    end for

    checklist.content = checklistContent
    checklist.checkedState = checkedState

    m.pluginRowsDialogSource = sourceName
    m.pluginRowsDialogSettingKey = settingKey
    m.pluginRowsDialogOptions = sortedRows
    m.pluginRowsDialogOptionMap = optionMap
    m.pluginRowsDialogSettingItem = settingItem
    m.top.getScene().dialog = dialog
end sub

sub onPluginRowsManagerDialogButton(event as object)
    dialog = event.getRoSGNode()
    buttonIndex = dialog.buttonSelected

    if buttonIndex = 0 and isValidAndNotEmpty(m.pluginRowsDialogSettingKey)
        checklist = dialog.findNode("checklist")
        checkedState = []
        checklistContent = invalid
        if isValid(checklist)
            checkedState = checklist.checkedState
            checklistContent = checklist.content
        end if

        savedRows = []
        if isValid(checklistContent)
            childCount = checklistContent.getChildCount()
            for i = 0 to childCount - 1
                listItem = checklistContent.getChild(i)
                itemId = LCase(dynamicToDisplayString(listItem.id).Trim())
                if not isValidAndNotEmpty(itemId)
                    continue for
                end if
                if not m.pluginRowsDialogOptionMap.DoesExist(itemId)
                    continue for
                end if

                option = m.pluginRowsDialogOptionMap[itemId]
                rowEnabled = false
                if i < checkedState.Count()
                    rowEnabled = checkedState[i]
                end if

                savedRows.push({
                    id: chainLookupReturn(option, "id", ""),
                    title: chainLookupReturn(option, "title", ""),
                    source: normalizeHomeRowsSourceName(chainLookupReturn(option, "source", m.pluginRowsDialogSource)),
                    kind: chainLookupReturn(option, "kind", ""),
                    route: chainLookupReturn(option, "route", ""),
                    additionalData: chainLookupReturn(option, "additionalData", invalid),
                    enabled: normalizeBoolSettingValue(rowEnabled),
                    order: i
                })
            end for
        else
            for i = 0 to m.pluginRowsDialogOptions.Count() - 1
                option = m.pluginRowsDialogOptions[i]
                rowEnabled = false
                if i < checkedState.Count()
                    rowEnabled = checkedState[i]
                end if

                savedRows.push({
                    id: chainLookupReturn(option, "id", ""),
                    title: chainLookupReturn(option, "title", ""),
                    source: normalizeHomeRowsSourceName(chainLookupReturn(option, "source", m.pluginRowsDialogSource)),
                    kind: chainLookupReturn(option, "kind", ""),
                    route: chainLookupReturn(option, "route", ""),
                    additionalData: chainLookupReturn(option, "additionalData", invalid),
                    enabled: normalizeBoolSettingValue(rowEnabled),
                    order: i
                })
            end for
        end if

        serialized = FormatJson(savedRows)
        set_user_setting(m.pluginRowsDialogSettingKey, serialized)
        session.user.settings.Save(m.pluginRowsDialogSettingKey, serialized)

        if isValid(m.pluginRowsDialogSettingItem)
            refreshCurrentItemValue(m.pluginRowsDialogSettingItem)
        end if
    end if

    dialog.close = true
    m.pluginRowsDialogSource = ""
    m.pluginRowsDialogSettingKey = ""
    m.pluginRowsDialogOptions = []
    m.pluginRowsDialogOptionMap = {}
    m.pluginRowsDialogSettingItem = invalid
    hideEditingControls()
    m.settingsMenu.setFocus(true)
end sub

function getSettingCurrentValueLabel(settingItem as dynamic) as string
    if not isValid(settingItem) then return ""
    if not isValid(settingItem.type) then return ""
    if not isValid(settingItem.settingName) then return ""

    if isPluginRowsManagerSetting(settingItem.settingName)
        return getPluginRowsManagerSummary(settingItem.settingName)
    end if

    if isStringEqual(settingItem.settingName, "jellyseerr.accountSettings")
        return GetJellyseerrAccountStatusLabel()
    end if

    if isStringEqual(settingItem.settingName, "jellyseerr.blockNsfw")
        config = GetJellyseerrConfig()
        if config.blockNsfw = true
            return tr("Enabled")
        end if
        return tr("Disabled")
    end if

    currentValue = get_user_setting(settingItem.settingName)
    if not isValid(currentValue) and isValid(m.global.session.user.settings[settingItem.settingName])
        currentValue = m.global.session.user.settings[settingItem.settingName]
    end if

    if isMediaBarMultiSelectSetting(settingItem.settingName)
        return getMediaBarSelectorSummary(settingItem.settingName, currentValue)
    end if

    if isStringEqual(settingItem.type, SettingType.BOOL)
        valueString = LCase(dynamicToDisplayString(currentValue))
        if isStringEqual(valueString, "true")
            return tr("Enabled")
        end if
        return tr("Disabled")
    end if

    if isStringEqual(settingItem.type, SettingType.RADIO)
        selectedValue = dynamicToDisplayString(currentValue)
        for each option in settingItem.options
            optionId = dynamicToDisplayString(option.id)
            if isStringEqual(optionId, selectedValue)
                return tr(chainLookupReturn(option, "title", optionId))
            end if
        end for
        return selectedValue
    end if

    if isStringEqual(settingItem.type, SettingType.SLIDER)
        selectedValue = dynamicToDisplayString(currentValue)
        for each option in settingItem.options
            optionValue = dynamicToDisplayString(option.value)
            if isStringEqual(optionValue, selectedValue)
                optionTitle = chainLookupReturn(option, "title", optionValue)
                if isValidAndNotEmpty(optionTitle)
                    return tr(optionTitle)
                end if
                return optionValue
            end if
        end for
        return selectedValue
    end if

    if isStringEqual(settingItem.type, SettingType.integer)
        return dynamicToDisplayString(currentValue)
    end if

    if isStringEqual(settingItem.type, SettingType.COLORGRID)
        return UCase(dynamicToDisplayString(currentValue))
    end if

    if isStringEqual(settingItem.type, SettingType.string)
        settingKeyLower = LCase(chainLookupReturn(settingItem, "settingName", ""))
        if InStr(settingKeyLower, "apikey") > 0 or InStr(settingKeyLower, "password") > 0
            return "********"
        end if
        return dynamicToDisplayString(currentValue)
    end if

    return ""
end function

sub refreshCurrentItemValue(settingItem = invalid as dynamic)
    if not isValid(settingItem)
        settingItem = getFocusedSetting()
    end if
    if not isValid(settingItem) then return
    if not isValid(m.settingsMenu) or not isValid(m.settingsMenu.content) then return

    focusIndex = m.settingsMenu.itemFocused
    if focusIndex < 0 then return

    contentItem = m.settingsMenu.content.getChild(focusIndex)
    if not isValid(contentItem) then return

    contentItem.currentValue = getSettingCurrentValueLabel(settingItem)
end sub

' Sync a setting to the server via PostTask (render-thread safe).
sub syncSettingToServer(rokuKey as string, rokuValue as dynamic)
    pushData = settingsSync.PreparePush(rokuKey, rokuValue)
    if not isValid(pushData) then return

    m.settingsSyncTask = createObject("roSGNode", "PostTask")
    m.settingsSyncTask.apiUrl = pushData.url
    m.settingsSyncTask.stringData = pushData.body
    m.settingsSyncTask.control = "RUN"
end sub

function getUserSettingValue(settingName as string, defaultValue = invalid as dynamic) as dynamic
    value = get_user_setting(settingName)
    if isValid(value)
        return value
    end if

    settings = chainLookupReturn(m.global, "session.user.settings", invalid)
    if isValid(settings) and isValid(settings[settingName])
        return settings[settingName]
    end if

    return defaultValue
end function

function shouldUseServerManagedHomeRows() as boolean
    return normalizeBoolSettingValue(getUserSettingValue("homeRows.useServerConfig", false))
end function

function getHomeSectionOrder() as object
    rowOrder = []

    for i = 0 to 7
        sectionKey = "homeScreenSection" + i.ToStr()
        sectionValue = LCase(dynamicToDisplayString(getUserSettingValue(sectionKey, "none")))
        if isValidAndNotEmpty(sectionValue) and sectionValue <> "none"
            rowOrder.push(sectionValue)
        end if
    end for

    return rowOrder
end function

function normalizeHomeRowsSourceName(sourceValue as dynamic) as string
    source = LCase(dynamicToDisplayString(sourceValue))

    if isStringEqual(source, "kefin") or isStringEqual(source, "kefintweak") or isStringEqual(source, "kefintweaks")
        return "kefintweaks"
    end if

    return source
end function

function isPluginRowsManagerSetting(settingName as dynamic) as boolean
    if not isValid(settingName) then return false

    if isStringEqual(settingName, "homeRows.manageHssRows") then return true
    if isStringEqual(settingName, "homeRows.manageKtRows") then return true
    return false
end function

function getPluginRowsManagerSource(settingName as dynamic) as string
    if not isPluginRowsManagerSetting(settingName)
        return ""
    end if

    if isStringEqual(settingName, "homeRows.manageHssRows") then return "hss"
    return "kefintweaks"
end function

function getPluginRowsManagerStorageKey(sourceName as dynamic) as string
    source = normalizeHomeRowsSourceName(sourceName)

    if isStringEqual(source, "hss") then return HOME_ROWS_HSS_LOCAL_SETTING
    if isStringEqual(source, "kefintweaks") then return HOME_ROWS_KT_LOCAL_SETTING
    return ""
end function

function parsePluginRowsConfigValue(value as dynamic) as object
    if not isValid(value)
        return []
    end if

    parsed = invalid
    valueType = type(value)
    if valueType = "Array" or valueType = "roArray"
        parsed = value
    else if valueType = "String" or valueType = "roString"
        parsed = ParseJson(value)
    end if

    if type(parsed) <> "Array" and type(parsed) <> "roArray"
        return []
    end if

    rows = []
    for each row in parsed
        rowType = type(row)
        if rowType = "AssociativeArray" or rowType = "roAssociativeArray"
            rows.push(row)
        end if
    end for

    return rows
end function

function parseIntSettingValue(value as dynamic, defaultValue = 0 as integer) as integer
    if not isValid(value)
        return defaultValue
    end if

    valueType = type(value)
    if valueType = "Integer" or valueType = "LongInteger" or valueType = "roInteger" or valueType = "roInt"
        return value
    end if

    if valueType = "Float" or valueType = "Double" or valueType = "roFloat" or valueType = "roDouble"
        return Int(value)
    end if

    if valueType = "String" or valueType = "roString"
        return Int(Val(value))
    end if

    return defaultValue
end function

function buildPluginRowsConfigMap(configRows as object) as object
    configMap = {}
    if not isValid(configRows)
        return configMap
    end if

    for each row in configRows
        rowId = LCase(dynamicToDisplayString(chainLookupReturn(row, "id", "")).Trim())
        if isValidAndNotEmpty(rowId)
            configMap[rowId] = row
        end if
    end for

    return configMap
end function

function getPluginRowsManagerSummary(settingName as dynamic) as string
    sourceName = getPluginRowsManagerSource(settingName)
    settingKey = getPluginRowsManagerStorageKey(sourceName)
    if not isValidAndNotEmpty(settingKey)
        return tr("Configure")
    end if

    savedRows = parsePluginRowsConfigValue(getUserSettingValue(settingKey, "[]"))
    if savedRows.Count() = 0
        return tr("Configure")
    end if

    enabledCount = 0
    for each row in savedRows
        if normalizeBoolSettingValue(chainLookupReturn(row, "enabled", false))
            enabledCount++
        end if
    end for

    return enabledCount.ToStr() + "/" + savedRows.Count().ToStr() + " " + tr("enabled")
end function

function buildHomeRowsV2Payload(rowOrder = invalid as dynamic) as object
    rows = []
    if not isValid(rowOrder)
        rowOrder = getHomeSectionOrder()
    end if

    for i = 0 to rowOrder.Count() - 1
        sectionId = rowOrder[i]
        rows.push({
            id: sectionId,
            title: sectionId,
            kind: "builtin",
            source: "jellyfin",
            enabled: true,
            order: i
        })
    end for

    return rows
end function

sub syncHomeRowsContractToServer()
    if not settingsSync.IsSyncEnabled()
        return
    end if

    rowOrder = getHomeSectionOrder()
    rowsV2 = buildHomeRowsV2Payload(rowOrder)

    m.homeRowsSyncTask = createObject("roSGNode", "PostTask")
    m.homeRowsSyncTask.apiUrl = "/Moonfin/HomeRows/tv"
    m.homeRowsSyncTask.stringData = FormatJson({
        source: "moonfin",
        rows: rowsV2,
        homeRowOrder: rowOrder,
        clientId: "roku"
    })
    m.homeRowsSyncTask.control = "RUN"
end sub

sub onSliderSelected()
    if not m.slider.hasFocus() then return

    if not isValid(m.slider.value) then return

    selectedSetting = getFocusedSetting()
    if not isValid(selectedSetting) then return

    for each option in selectedSetting.options
        if not isValid(option.data) then continue for

        if isStringEqual(option.value, m.slider.value)
            set_user_setting(`${selectedSetting.settingName}Data`, option.data)
            exit for
        end if
    end for

    set_user_setting(selectedSetting.settingName, m.slider.value)
    syncSettingToServer(selectedSetting.settingName, m.slider.value)
    refreshCurrentItemValue(selectedSetting)
    hideEditingControls()
    m.settingsMenu.setFocus(true)
end sub

sub onColorSelected()
    selectedColor = m.colorgrid.content.getChild(m.colorgrid.itemSelected).colorCode
    m.colorgrid.selectedColor = selectedColor

    selectedSetting = getFocusedSetting()
    if not isValid(selectedSetting) then return

    set_user_setting(selectedSetting.settingName, selectedColor ?? ColorPalette.VIEWBACKGROUND)

    scene = m.top.getScene()

    if isStringEqual(selectedSetting.settingName, "colorBackground") and isValid(scene)
        scene.backgroundColor = selectedColor ?? ColorPalette.VIEWBACKGROUND
    end if

    if isStringEqual(selectedSetting.settingName, "colorCursor") and isValid(scene)
        activeNav = getActiveNav(scene)
        if isValid(activeNav)
            overlayCurrentUserSelection = activeNav.findNode("overlayCurrentUserSelection")
            if isValid(overlayCurrentUserSelection)
                overlayCurrentUserSelection.blendColor = selectedColor ?? ColorPalette.HIGHLIGHT
            end if
        end if

        'm.settingsMenu.focusBitmapBlendColor = selectedColor ?? ColorPalette.HIGHLIGHT
    end if

    if isStringEqual(selectedSetting.settingName, "colorHomeUsername") and isValid(scene)
        activeNav = getActiveNav(scene)
        if isValid(activeNav)
            overlayCurrentUser = activeNav.findNode("overlayCurrentUser")
            if isValid(overlayCurrentUser)
                overlayCurrentUser.color = selectedColor ?? ColorPalette.WHITE
            end if
        end if
    end if

    refreshCurrentItemValue(selectedSetting)
    hideEditingControls()
    m.settingsMenu.setFocus(true)
end sub

sub onKeyGridSubmit()
    selectedSetting = getFocusedSetting()
    if not isValid(selectedSetting) then return

    if isValid(selectedSetting.max) and m.integerSetting.text.ToInt() > selectedSetting.max.ToInt()
        m.integerSetting.text = selectedSetting.max
        return
    end if
    set_user_setting(selectedSetting.settingName, m.integerSetting.text)
    syncSettingToServer(selectedSetting.settingName, m.integerSetting.text)
    refreshCurrentItemValue(selectedSetting)
    hideEditingControls()
    m.settingsMenu.setFocus(true)
end sub

sub onKeyGridEscape()
    if m.integerSetting.escape = "left" or m.integerSetting.escape = "back"
        hideEditingControls()
        m.settingsMenu.setFocus(true)
    end if
end sub

sub showStringInputDialog(settingItem as object)
    ' Show keyboard dialog for string input
    m.currentStringSetting = settingItem

    ' Get current value
    currentValue = get_user_setting(settingItem.settingName)
    if not isValid(currentValue) then currentValue = ""

    ' Determine if this is a password/secure field
    isSecure = (InStr(LCase(settingItem.settingName), "password") > 0 or InStr(LCase(settingItem.settingName), "apikey") > 0)

    ' Create keyboard dialog
    dialog = createObject("roSGNode", "StandardKeyboardDialog")
    dialog.title = tr(settingItem.title)
    dialog.text = currentValue

    if isSecure
        dialog.textEditBox.secureMode = true
    end if

    ' Set palette
    dlgPalette = createObject("roSGNode", "RSGPalette")
    dlgPalette.colors = {
        DialogBackgroundColor: chainLookupReturn(m.global.session, "user.settings.colorDialogBackground", ColorPalette.ELEMENTBACKGROUND),
        DialogFocusColor: chainLookupReturn(m.global.session, "user.settings.colorCursor", ColorPalette.HIGHLIGHT),
        DialogFocusItemColor: chainLookupReturn(m.global.session, "user.settings.colorDialogSelectedText", ColorPalette.WHITE),
        DialogTextColor: chainLookupReturn(m.global.session, "user.settings.colorDialogText", ColorPalette.WHITE)
    }
    dialog.palette = dlgPalette
    dialog.buttons = [tr("OK"), tr("Cancel")]

    m.stringInputDialog = dialog
    dialog.observeField("buttonSelected", "onStringInputDialogButton")
    m.top.getScene().dialog = dialog
end sub

sub onStringInputDialogButton(event as object)
    dialog = event.getRoSGNode()
    buttonIndex = dialog.buttonSelected
    updatedSetting = m.currentStringSetting

    if buttonIndex = 0 ' OK pressed
        ' Save the value
        newValue = dialog.text
        if isValid(m.currentStringSetting)
            set_user_setting(m.currentStringSetting.settingName, newValue)

            ' Special handling for Jellyseerr settings - update registry directly
            if InStr(m.currentStringSetting.settingName, "jellyseerr.") > 0
                sec = CreateObject("roRegistrySection", "jellyseerr")
                settingKey = Right(m.currentStringSetting.settingName, Len(m.currentStringSetting.settingName) - 11) ' Remove "jellyseerr." prefix
                sec.Write(settingKey, newValue)
                sec.Flush()

                ' Auto-authenticate if Jellyfin password was entered
                if m.currentStringSetting.settingName = "jellyseerr.jellyfinPassword" and newValue <> ""
                    ' Close dialog first
                    dialog.close = true
                    m.settingsMenu.setFocus(true)
                    m.currentStringSetting = invalid
                    refreshCurrentItemValue(updatedSetting)

                    ' Trigger Jellyfin authentication
                    testJellyseerrConnection("jellyfin")
                    return
                end if
            end if
        end if
    end if

    ' Close dialog and return focus
    dialog.close = true
    m.settingsMenu.setFocus(true)
    m.currentStringSetting = invalid
    refreshCurrentItemValue(updatedSetting)
end sub

sub testJellyseerrConnection(overrideAuthMethod = invalid as dynamic)
    ' Get the server URL
    serverUrl = m.global.session.user.settings["jellyseerr.url"]

    if serverUrl = invalid or serverUrl = ""
        ShowToast("Please enter Server URL first", "error")
        return
    end if

    ' Determine auth method: use override if provided, otherwise detect from which setting triggered this
    authMethod = invalid
    if isValid(overrideAuthMethod) and overrideAuthMethod <> ""
        authMethod = overrideAuthMethod
    end if

    if authMethod = "apikey" or authMethod = invalid
        apiKey = m.global.session.user.settings["jellyseerr.apiKey"]

        if apiKey = invalid or apiKey = ""
            if authMethod = "apikey"
                ShowToast("Please enter API Key first", "error")
                return
            end if
            ' If no specific method and no API key, skip this method
        else
            ' Use API Key auth
            authMethod = "apikey"

            ' Save credentials to registry first so the API task can use them
            sec = CreateObject("roRegistrySection", "jellyseerr")
            sec.Write("serverUrl", serverUrl)
            sec.Write("apiKey", apiKey)
            sec.Write("authMethod", "apikey")
            sec.Flush()

            ' Create API task to test connection
            testTask = CreateObject("roSGNode", "JellyseerrAPITask")
            testTask.request = {
                method: "GET",
                endpoint: "/api/v1/user"
            }
            testTask.observeField("response", "onApiKeyTestResponse")
            testTask.control = "RUN"
            m.testConnectionTask = testTask
            return
        end if
    end if

    if authMethod = "jellyfin" or authMethod = invalid
        ' Use the currently logged-in Jellyfin user's name
        username = m.global.session.user.name
        password = m.global.session.user.settings["jellyseerr.jellyfinPassword"]

        if not isValidString(username)
            if authMethod = "jellyfin"
                ShowToast("Unable to get Jellyfin username", "error")
                return
            end if
            ' If no specific method and no username, skip this method
        else if password = invalid or not isValidString(password)
            if authMethod = "jellyfin"
                ShowToast("Please enter your Jellyfin password", "error")
                return
            end if
            ' If no specific method and no password, skip this method
        else
            ' Use Jellyfin auth
            authMethod = "jellyfin"

            ' Create authentication task
            authTask = CreateObject("roSGNode", "JellyseerrAuthTask")
            authTask.serverUrl = serverUrl
            authTask.authEndpoint = "/api/v1/auth/jellyfin"
            authTask.authBody = JellyseerrFormatJson({
                username: username,
                password: password
            })
            authTask.observeField("response", "onJellyfinAuthResponse")
            authTask.control = "RUN"
            m.authTask = authTask
            return
        end if
    end if

    if authMethod = "local" or authMethod = invalid
        email = m.global.session.user.settings["jellyseerr.localEmail"]
        password = m.global.session.user.settings["jellyseerr.localPassword"]

        if email = invalid or email = "" or password = invalid or password = ""
            if authMethod = "local"
                ShowToast("Please enter Seerr email and password", "error")
                return
            end if
            ' If no specific method provided, we've exhausted all options
            ShowToast("Please configure one of the authentication methods", "error")
            return
        end if

        ' Create authentication task
        authTask = CreateObject("roSGNode", "JellyseerrAuthTask")
        authTask.serverUrl = serverUrl
        authTask.authEndpoint = "/api/v1/auth/local"
        authTask.authBody = JellyseerrFormatJson({
            email: email,
            password: password
        })
        authTask.observeField("response", "onLocalAuthResponse")
        authTask.control = "RUN"
        m.authTask = authTask
    end if
end sub

sub testPluginConnection()
    if isValid(m.pluginPingTask)
        m.pluginPingTask.unobserveField("result")
    end if

    m.pluginPingTask = createObject("roSGNode", "PluginPingTask")
    m.pluginPingTask.observeField("result", "onPluginPingComplete")
    m.pluginPingTask.control = "RUN"
end sub

sub onPluginPingComplete()
    if not isValid(m.pluginPingTask) then return

    result = m.pluginPingTask.result
    m.pluginPingTask.unobserveField("result")
    m.pluginPingTask = invalid

    if isValid(result) and (result.success ?? false)
        pluginInfo = {
            installed: true,
            version: result.version ?? "unknown",
            settingsSyncEnabled: result.settingsSyncEnabled ?? false,
            mdblistAvailable: result.mdblistAvailable ?? false,
            tmdbAvailable: result.tmdbAvailable ?? false,
            jellyseerrEnabled: result.jellyseerrEnabled ?? false,
            jellyseerrVariant: result.variant ?? "seerr",
            defaultSettings: result.defaultSettings ?? invalid
        }
        tmpSession = m.global.session
        tmpSession.AddReplace("pluginInfo", pluginInfo)
        m.global.setFields({ session: tmpSession })
    else
        ShowToast("Could not connect to Moonfin Plugin. Ensure the plugin is installed on your Jellyfin server.", "error")
        set_user_setting("plugin.enabled", "false")
        session.user.settings.Save("plugin.enabled", "false")
    end if

    updateHssSettingGate()
    updateKtSettingGate()
    if m.userLocation.Count() > 0
        RefreshCurrentMenu()
    end if
end sub

sub onApiKeyTestResponse(event as object)
    response = event.getData()

    ' Build detailed message for modal
    dialogMessage = ""
    if response.success
        dialogMessage = "Connection successful! API key is valid."
        if response.rawResponse <> invalid and response.rawResponse <> ""
            dialogMessage = dialogMessage + Chr(10) + Chr(10) + "Server Response:" + Chr(10) + response.rawResponse
        end if
    else
        dialogMessage = "Connection failed"
        if response.error <> invalid and response.error <> ""
            dialogMessage = dialogMessage + Chr(10) + Chr(10) + "Error: " + response.error
        end if
        if response.statusCode <> invalid
            dialogMessage = dialogMessage + Chr(10) + "Status Code: " + response.statusCode.ToStr()
        end if
    end if

    ' Show modal dialog using StandardMessageDialog
    dialog = createObject("roSGNode", "StandardMessageDialog")
    dialog.title = "API Key Test"
    dialog.message = dialogMessage
    dialog.buttons = ["OK"]
    dialog.observeField("buttonSelected", "onAuthModalClosed")
    m.top.getScene().dialog = dialog

    ' Refresh the settings display to show updated auth status
    if response.success then settingFocused()
end sub

sub onJellyfinAuthResponse(event as object)
    response = event.getData()

    dialogMessage = ""
    dialogTitle = "Seerr Authentication"

    if response <> invalid and response.success
        ' For Jellyfin auth, we need to save the session cookie, not an API key
        if response.cookies <> invalid and response.cookies <> ""
            ' Get current user ID and save to per-user registry
            userId = GetCurrentJellyfinUserId()
            if userId = ""
                dialogTitle = "Error"
                dialogMessage = "Unable to get current user ID"
            else
                serverUrl = m.global.session.user.settings["jellyseerr.url"]

                ' Save to global registry (serverUrl)
                SetJellyseerrGlobalConfig(serverUrl, true)

                ' Save to per-user registry (cookie and auth method)
                SetJellyseerrUserConfig(userId, response.cookies, "jellyfin", "", "", "")

                ' Fetch user permissions after successful auth
                FetchJellyseerrUserPermissions(userId)

                dialogTitle = "Authentication Successful"
                dialogMessage = "Successfully connected to Seerr!" + Chr(10) + Chr(10)
                dialogMessage = dialogMessage + "Your credentials have been saved and will persist across sessions."

                ' Mark session as validated for this app session
                if m.global <> invalid
                    m.global.addFields({ jellyseerrSessionValidated: true })
                end if

                ' Refresh the settings display to show updated auth status
                settingFocused()
            end if
        else
            dialogTitle = "Connected (No Cookie)"
            dialogMessage = "Authentication succeeded but no session cookie was returned." + Chr(10) + Chr(10)
            dialogMessage = dialogMessage + "Status Code: " + response.statusCode.ToStr() + Chr(10) + Chr(10)
            dialogMessage = dialogMessage + "Please check your Seerr server configuration."
        end if
    else
        dialogTitle = "Authentication Failed"
        dialogMessage = "Jellyfin authentication failed" + Chr(10) + Chr(10)

        if response <> invalid
            dialogMessage = dialogMessage + "Status Code: " + response.statusCode.ToStr() + Chr(10)

            if response.error <> invalid and response.error <> ""
                dialogMessage = dialogMessage + "Error: " + response.error + Chr(10)
            end if

            if response.rawResponse <> invalid and response.rawResponse <> ""
                ' Show first 200 chars of error response
                errorPreview = response.rawResponse
                if Len(errorPreview) > 200
                    errorPreview = Left(errorPreview, 200) + "..."
                end if
                dialogMessage = dialogMessage + Chr(10) + "Response: " + errorPreview
            end if
        else
            dialogMessage = dialogMessage + "No response received from server."
        end if
    end if

    ' Show modal dialog
    if dialogTitle <> invalid and dialogTitle <> "" and dialogMessage <> invalid and dialogMessage <> ""
        dialog = CreateObject("roSGNode", "StandardMessageDialog")
        if dialog <> invalid
            dialog.title = dialogTitle
            dialog.message = [dialogMessage]
            dialog.buttons = ["OK"]
            dialog.observeField("buttonSelected", "onAuthModalClosed")
            m.top.getScene().dialog = dialog
        end if
    end if
end sub

sub onLocalAuthResponse(event as object)
    response = event.getData()

    dialogMessage = ""
    dialogTitle = "Seerr Authentication"

    if response <> invalid and response.success
        ' Local auth can also use cookies like Jellyfin auth
        if response.cookies <> invalid and response.cookies <> ""
            ' Get current user ID and save to per-user registry
            userId = GetCurrentJellyfinUserId()
            if userId = ""
                dialogTitle = "Error"
