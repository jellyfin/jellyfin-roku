                ' Save to per-user registry (cookie and auth method)
                SetJellyseerrUserConfig(userId, response.cookies, "local", "", "", "")

                ' Fetch user permissions after successful auth
                FetchJellyseerrUserPermissions(userId)

                dialogTitle = "Authentication Successful"
                dialogMessage = "Successfully connected to Seerr!" + Chr(10) + Chr(10)
                dialogMessage = dialogMessage + "Your credentials have been saved and will persist across sessions."

                ' Mark session as validated for this app session
                if m.global <> invalid
                    m.global.addFields({ jellyseerrSessionValidated: true })
                end if

                ' Refresh the settings display to show updated auth status
                settingFocused()
            end if
        else
            dialogTitle = "Connected (No Cookie)"
            dialogMessage = "Authentication succeeded but no session cookie was returned." + Chr(10) + Chr(10)
            dialogMessage = dialogMessage + "Status Code: " + response.statusCode.ToStr() + Chr(10) + Chr(10)
            dialogMessage = dialogMessage + "Please check your Seerr server configuration."
        end if
    else
        dialogTitle = "Authentication Failed"
        dialogMessage = "Seerr authentication failed" + Chr(10) + Chr(10)

        if response <> invalid
            dialogMessage = dialogMessage + "Status Code: " + response.statusCode.ToStr() + Chr(10)

            if response.error <> invalid and response.error <> ""
                dialogMessage = dialogMessage + "Error: " + response.error + Chr(10)
            end if

            if response.rawResponse <> invalid and response.rawResponse <> ""
                ' Show first 200 chars of error response
                errorPreview = response.rawResponse
                if Len(errorPreview) > 200
                    errorPreview = Left(errorPreview, 200) + "..."
                end if
                dialogMessage = dialogMessage + Chr(10) + "Response: " + errorPreview
            end if
        else
            dialogMessage = dialogMessage + "No response received from server."
        end if
    end if

    ' Show modal dialog
    if dialogTitle <> invalid and dialogTitle <> "" and dialogMessage <> invalid and dialogMessage <> ""
        dialog = CreateObject("roSGNode", "StandardMessageDialog")
        if dialog <> invalid
            dialog.title = dialogTitle
            dialog.message = [dialogMessage]
            dialog.buttons = ["OK"]
            dialog.observeField("buttonSelected", "onAuthModalClosed")
            m.top.getScene().dialog = dialog
        end if
    end if
end sub

function GetJellyseerrAuthStatus() as string
    ' Check current authentication status for Seerr
    serverUrl = m.global.session.user.settings["jellyseerr.url"]

    if not isValidString(serverUrl)
        return "Status: Not configured - Please enter Server URL"
    end if

    ' Check registry for saved authentication (indicates successful auth)
    sec = CreateObject("roRegistrySection", "jellyseerr")
    savedApiKey = sec.Read("apiKey")
    savedAuthCookie = sec.Read("authCookie")
    savedServerUrl = sec.Read("serverUrl")
    savedAuthMethod = sec.Read("authMethod")

    if savedServerUrl = serverUrl and (isValidString(savedApiKey) or isValidString(savedAuthCookie))
        methodDisplay = "API Key"
        if savedAuthMethod = "jellyfin"
            methodDisplay = "Jellyfin SSO"
        else if savedAuthMethod = "local"
            methodDisplay = "Seerr Login"
        end if
        return "Status: Authenticated (" + methodDisplay + ")"
    end if

    return "Status: Not authenticated - Configure one of the login methods below"
end function

' Helper function to check if a value is a valid non-empty string
function isValidString(value as dynamic) as boolean
    if value = invalid then return false
    if type(value) <> "String" and type(value) <> "roString" then return false
    return value <> ""
end function

sub ShowToast(message as string, _toastType = "" as string)
    if m.activeToast <> invalid
        DismissToast()
    end if

    toastMessage = ""
    if message <> invalid
        if type(message) = "String" or type(message) = "roString"
            toastMessage = message.Trim()
        else
            toastMessage = message.ToStr()
        end if
    end if
    if toastMessage = ""
        toastMessage = "Done."
    end if

    ' Create a simple toast notification using JFMessageDialog
    toast = createObject("roSGNode", "JFMessageDialog")
    toast.message = toastMessage
    toast.options = ["OK"]
    m.top.getScene().appendChild(toast)

    optionList = toast.findNode("optionList")
    if optionList <> invalid
        optionList.observeField("itemSelected", "onToastOptionSelected")
    end if

    m.activeToast = toast
    toast.observeField("backPressed", "onToastClosed")
    toast.setFocus(true)
end sub

sub onToastOptionSelected(_obj as object)
    DismissToast()
end sub

' Handle toast dialog closed
sub onToastClosed(_obj as object)
    DismissToast()
end sub

sub DismissToast()
    if m.activeToast = invalid
        return
    end if

    optionList = m.activeToast.findNode("optionList")
    if optionList <> invalid
        optionList.unobserveField("itemSelected")
    end if
    m.activeToast.unobserveField("backPressed")

    scene = m.top.getScene()
    if scene <> invalid
        scene.removeChild(m.activeToast)
    end if

    m.activeToast = invalid
    m.settingsMenu.setFocus(true)
end sub

sub openJellyseerrAuthScreen()
    ' Open the Jellyseerr authentication screen
    authScreen = CreateObject("roSGNode", "JellyseerrAuthScreen")
    m.top.getScene().appendChild(authScreen)
    authScreen.setFocus(true)
end sub

sub PopulateSeerrAccountChildren(section as object)
    m.seerrAccountSection = section
    userId = chainLookupReturn(m.global, "session.user.id", "")
    userConfig = GetJellyseerrUserConfig(userId)
    isLoggedIn = isValid(userConfig) and isValidAndNotEmpty(userConfig.displayName)

    if isLoggedIn
        displayName = userConfig.displayName
        section.children = [
            {
                title: "Signed in as " + displayName,
                description: "You are currently authenticated with Seerr.",
                settingName: "jellyseerr.accountStatus",
                type: "action"
            },
            {
                title: "Sign Out",
                description: "Sign out from your Seerr account.",
                settingName: "jellyseerr.signOut",
                type: "action"
            }
        ]
    else
        config = GetJellyseerrConfig()
        pluginAvailable = (config.usePluginProxy ?? false) and (config.serverUrl ?? "") <> ""
        if pluginAvailable
            section.children = [
                {
                    title: "Sign in with Jellyfin",
                    description: "Use your Jellyfin credentials to sign in to Seerr.",
                    settingName: "jellyseerr.signIn.jellyfin",
                    type: "action"
                },
                {
                    title: "Sign in with Local Account",
                    description: "Use a local Seerr account (email and password).",
                    settingName: "jellyseerr.signIn.local",
                    type: "action"
                }
            ]
        else
            section.children = [
                {
                    title: "Not signed in",
                    description: "Seerr plugin authentication is unavailable. Ask your server admin to enable the Seerr plugin.",
                    settingName: "jellyseerr.accountStatus",
                    type: "action"
                }
            ]
        end if
    end if
end sub

sub StartSeerrJellyfinSignIn()
    m.seerrKeyboardMode = "jellyfin_username"
    defaultUsername = ""
    if m.global <> invalid and m.global.session <> invalid and m.global.session.user <> invalid and m.global.session.user.name <> invalid
        defaultUsername = m.global.session.user.name
    end if
    ShowSeerrKeyboard("Jellyfin Username", defaultUsername, false)
end sub

sub StartSeerrLocalSignIn()
    m.seerrKeyboardMode = "local_username"
    ShowSeerrKeyboard("Email", "", false)
end sub

sub ShowSeerrKeyboard(title as string, initialValue as string, isPassword as boolean)
    dialog = CreateObject("roSGNode", "StandardKeyboardDialog")
    dialog.title = tr(title)
    dialog.text = initialValue
    if isPassword
        dialog.textEditBox.secureMode = true
    end if
    dlgPalette = CreateObject("roSGNode", "RSGPalette")
    dlgPalette.colors = {
        DialogBackgroundColor: chainLookupReturn(m.global.session, "user.settings.colorDialogBackground", ColorPalette.ELEMENTBACKGROUND),
        DialogFocusColor: chainLookupReturn(m.global.session, "user.settings.colorCursor", ColorPalette.HIGHLIGHT),
        DialogFocusItemColor: chainLookupReturn(m.global.session, "user.settings.colorDialogSelectedText", ColorPalette.WHITE),
        DialogTextColor: chainLookupReturn(m.global.session, "user.settings.colorDialogText", ColorPalette.WHITE)
    }
    dialog.palette = dlgPalette
    dialog.buttons = [tr("OK"), tr("Cancel")]
    dialog.observeField("buttonSelected", "onSeerrKeyboardButton")
    m.top.getScene().dialog = dialog
end sub

sub onSeerrKeyboardButton(event as object)
    dialog = event.getRoSGNode()
    buttonIndex = dialog.buttonSelected

    if buttonIndex <> 0 ' Cancel
        dialog.close = true
        m.seerrKeyboardMode = ""
        m.seerrTempUsername = ""
        m.settingsMenu.setFocus(true)
        return
    end if

    enteredText = dialog.text
    dialog.close = true

    if m.seerrKeyboardMode = "jellyfin_username"
        m.seerrTempUsername = enteredText
        m.seerrKeyboardMode = "jellyfin_password"
        ShowSeerrKeyboard("Jellyfin Password", "", true)
    else if m.seerrKeyboardMode = "jellyfin_password"
        username = m.seerrTempUsername
        m.seerrTempUsername = ""
        m.seerrKeyboardMode = ""
        PerformSeerrPluginLogin("jellyfin", username, enteredText)
    else if m.seerrKeyboardMode = "local_username"
        m.seerrTempUsername = enteredText
        m.seerrKeyboardMode = "local_password"
        ShowSeerrKeyboard("Password", "", true)
    else if m.seerrKeyboardMode = "local_password"
        username = m.seerrTempUsername
        m.seerrTempUsername = ""
        m.seerrKeyboardMode = ""
        PerformSeerrPluginLogin("local", username, enteredText)
    end if
    m.settingsMenu.setFocus(true)
end sub

sub PerformSeerrPluginLogin(authType as string, username as string, password as string)
    config = GetJellyseerrConfig()
    if not (config.usePluginProxy ?? false) or (config.serverUrl ?? "") = ""
        ShowToast("Seerr plugin authentication is unavailable.", "error")
        return
    end if

    authBody = JellyseerrFormatJson({
        username: username,
        password: password,
        authType: authType
    })

    if isValid(m.seerrAuthTask)
        m.seerrAuthTask.unobserveField("response")
    end if
    m.seerrAuthTask = CreateObject("roSGNode", "JellyseerrAuthTask")
    m.seerrAuthTask.serverUrl = config.serverUrl
    m.seerrAuthTask.authBody = authBody
    m.seerrAuthTask.usePluginProxy = true
    m.seerrAuthTask.observeField("response", "onSeerrLoginResponse")
    m.seerrAuthTask.control = "RUN"
end sub

sub onSeerrLoginResponse()
    if not isValid(m.seerrAuthTask) then return
    response = m.seerrAuthTask.response
    m.seerrAuthTask.unobserveField("response")
    m.seerrAuthTask = invalid
    HandleSeerrLoginResult(response)
end sub

sub HandleSeerrLoginResult(response as object)
    if not isValid(response) or not (response.success ?? false)
        errMsg = "Login failed"
        if isValid(response) and isValid(response.error) and response.error <> ""
            errMsg = response.error
        end if
        ShowToast(errMsg, "error")
        return
    end if

    userId = chainLookupReturn(m.global, "session.user.id", "")
    displayName = ""
    if isValid(response.displayName) then displayName = response.displayName
    jellyseerrUserId = 0
    if isValid(response.jellyseerrUserId) then jellyseerrUserId = int(response.jellyseerrUserId)
    permissions = 0
    if isValid(response.permissions) then permissions = int(response.permissions)
    avatar = ""
    if isValid(response.avatar) then avatar = response.avatar

    SetJellyseerrUserIdentity(userId, jellyseerrUserId, displayName, permissions, avatar)

    RefreshSeerrAccountMenu()
end sub

sub PerformSeerrSignOut()
    config = GetJellyseerrConfig()
    if not (config.usePluginProxy ?? false) or (config.serverUrl ?? "") = ""
        ' Just clear locally
        userId = chainLookupReturn(m.global, "session.user.id", "")
        ClearJellyseerrUserIdentity(userId)
        RefreshSeerrAccountMenu()
        return
    end if

    if isValid(m.seerrLogoutTask)
        m.seerrLogoutTask.unobserveField("response")
    end if
    m.seerrLogoutTask = CreateObject("roSGNode", "JellyseerrAPITask")
    m.seerrLogoutTask.request = {
        method: "DELETE",
        endpoint: "/Moonfin/Jellyseerr/Logout",
        usePluginRoot: true
    }
    m.seerrLogoutTask.observeField("response", "onSeerrLogoutResponse")
    m.seerrLogoutTask.control = "RUN"
end sub

sub onSeerrLogoutResponse()
    if not isValid(m.seerrLogoutTask) then return
    m.seerrLogoutTask.unobserveField("response")
    m.seerrLogoutTask = invalid

    userId = chainLookupReturn(m.global, "session.user.id", "")
    ClearJellyseerrUserIdentity(userId)
    RefreshSeerrAccountMenu()
end sub

sub RefreshSeerrAccountMenu()
    if not isValid(m.seerrAccountSection) then return
    PopulateSeerrAccountChildren(m.seerrAccountSection)
    m.userLocation.pop()
    LoadMenu(m.seerrAccountSection)
end sub

function GetJellyseerrAccountStatusLabel() as string
    userId = chainLookupReturn(m.global, "session.user.id", "")
    userConfig = GetJellyseerrUserConfig(userId)

    if isValid(userConfig) and isValidAndNotEmpty(userConfig.displayName)
        return "Signed in as " + userConfig.displayName
    end if

    if isValid(userConfig) and isValidAndNotEmpty(userConfig.authCookie)
        authMethod = chainLookupReturn(userConfig, "authMethod", "")
        if isStringEqual(authMethod, "jellyfin")
            return "Signed in (Jellyfin)"
        end if
        if isStringEqual(authMethod, "local")
            return "Signed in (Seerr account)"
        end if
        return "Signed in"
    end if

    return "Not signed in"
end function

sub RefreshCurrentMenu()
    ' Reload the current menu level to apply visibility changes
    currentSection = m.userLocation.peek()
    m.userLocation.pop()
    LoadMenu(currentSection, false)
    m.userLocation.push(currentSection)
end sub

sub dismissPanel()
    scene = m.top.getScene()

    OnScreenHidden()

    if isValid(scene)
        scene.removeChild(m.top)

        audioMiniPlayer = scene.findNode("audioMiniPlayer")
        shouldRestoreMiniPlayer = (m.top.restoreMiniPlayerOnClose = true)
        if isValid(audioMiniPlayer) and shouldRestoreMiniPlayer and m.global.audioPlayer.state <> "stopped"
            audioMiniPlayer.callFunc("setVisible", true)
        end if

        activeNav = getActiveNav(scene)
        if isValid(activeNav) and activeNav.visible
            activeNav.setFocus(true)
            return
        end if
    end if

    activeScene = m.global.sceneManager.callFunc("getActiveScene")
    if isValid(activeScene)
        if isValid(activeScene.lastFocus)
            activeScene.lastFocus.setFocus(true)
        else
            activeScene.setFocus(true)
        end if
    end if
end sub

function findSettingsSectionByTitle(sections as object, title as string) as dynamic
    if not isValid(sections) then return invalid

    for each item in sections
        if isStringEqual(chainLookupReturn(item, "title", ""), title)
            return item
        end if
    end for

    return invalid
end function

function findSettingsChildByTitle(section as object, title as string) as dynamic
    if not isValid(section) then return invalid
    if not isValid(section.children) then return invalid

    for each item in section.children
        if isStringEqual(chainLookupReturn(item, "title", ""), title)
            return item
        end if
    end for

    return invalid
end function

sub pushSettingIfValid(items as object, item as dynamic)
    if isValid(item)
        items.push(item)
    end if
end sub

function titleExistsInList(titles as object, title as string) as boolean
    if not isValid(titles) then return false

    for each itemTitle in titles
        if isStringEqual(itemTitle, title)
            return true
        end if
    end for

    return false
end function

sub pushUnmappedChildrenByTitle(items as object, section as dynamic, mappedTitles as object)
    if not isValid(items) then return
    if not isValid(section) or not isValid(section.children) then return

    for each child in section.children
        childTitle = chainLookupReturn(child, "title", "")
        if not isValidAndNotEmpty(childTitle) then continue for
        if titleExistsInList(mappedTitles, childTitle) then continue for
        items.push(child)
    end for
end sub

function normalizeBoolSettingValue(value as dynamic) as boolean
    if not isValid(value)
        return false
    end if

    if type(value) = "Boolean" or type(value) = "roBoolean"
        return value
    end if

    if type(value) = "String" or type(value) = "roString"
        return LCase(value) = "true"
    end if

    return false
end function

sub setUserBoolSetting(settingName as string, enabled as boolean, syncToServer = false as boolean)
    value = enabled ? "true" : "false"
    session.user.settings.Save(settingName, value)
    set_user_setting(settingName, value)

    if syncToServer
        syncSettingToServer(settingName, value)
    end if
end sub

function isHssPluginDetected() as boolean
    if not isValid(m.hssDetected)
        return true
    end if

    return m.hssDetected
end function

function isKtPluginDetected() as boolean
    if not isValid(m.ktDetected)
        return true
    end if

    return m.ktDetected
end function

sub setSettingVisibilityByName(items as object, settingName as string, isVisible as boolean)
    if not isValid(items)
        return
    end if

    for each item in items
        if isValid(item.settingName) and isStringEqual(item.settingName, settingName)
            item.visible = isVisible
        end if

        if isValid(item.children)
            setSettingVisibilityByName(item.children, settingName, isVisible)
        end if
    end for
end sub

sub refreshHssPluginDetection()
    if isValid(m.hssProbeTask)
        m.hssProbeTask.unobserveField("result")
        m.hssProbeTask.control = "STOP"
    end if

    m.hssProbeTask = createObject("roSGNode", "HSSProbeTask")
    m.hssProbeTask.serverUrl = chainLookupReturn(m.global, "session.server.url", "")
    m.hssProbeTask.userId = chainLookupReturn(m.global, "session.user.id", "")
    m.hssProbeTask.authToken = chainLookupReturn(m.global, "session.user.authToken", "")
    m.hssProbeTask.observeField("result", "onHssPluginProbeComplete")
    m.hssProbeTask.control = "RUN"
end sub

sub onHssPluginProbeComplete()
    if not isValid(m.hssProbeTask) then return

    result = m.hssProbeTask.result
    m.hssProbeTask.unobserveField("result")
    m.hssProbeTask = invalid

    m.hssDetected = normalizeBoolSettingValue(chainLookupReturn(result, "enabled", false))
    updateHssSettingGate()

    if m.userLocation.Count() > 0
        RefreshCurrentMenu()
    end if
end sub

sub refreshKtPluginDetection()
    if isValid(m.ktProbeTask)
        m.ktProbeTask.unobserveField("result")
        m.ktProbeTask.control = "STOP"
    end if

    m.ktProbeTask = createObject("roSGNode", "KefinTweaksProbeTask")
    m.ktProbeTask.serverUrl = chainLookupReturn(m.global, "session.server.url", "")
    m.ktProbeTask.userId = chainLookupReturn(m.global, "session.user.id", "")
    m.ktProbeTask.authToken = chainLookupReturn(m.global, "session.user.authToken", "")
    m.ktProbeTask.observeField("result", "onKtPluginProbeComplete")
    m.ktProbeTask.control = "RUN"
end sub

sub onKtPluginProbeComplete()
    if not isValid(m.ktProbeTask) then return

    result = m.ktProbeTask.result
    m.ktProbeTask.unobserveField("result")
    m.ktProbeTask = invalid

    m.ktDetected = normalizeBoolSettingValue(chainLookupReturn(result, "enabled", false))
    updateKtSettingGate()

    if m.userLocation.Count() > 0
        RefreshCurrentMenu()
    end if
end sub

sub updateHssSettingGate()
    if not isValid(m.configTree)
        return
    end if

    pluginDetected = isHssPluginDetected()
    usingServerRows = shouldUseServerManagedHomeRows()

    setSettingVisibilityByName(m.configTree, "plugin.hss.enabled", pluginDetected and not usingServerRows)
end sub

sub updateKtSettingGate()
    if not isValid(m.configTree)
        return
    end if

    pluginDetected = isKtPluginDetected()
    usingServerRows = shouldUseServerManagedHomeRows()

    setSettingVisibilityByName(m.configTree, "plugin.kefintweaks.enabled", pluginDetected and not usingServerRows)
end sub

function reorderSettingsForFlutter(configTree as object) as object
    if not isValid(configTree) then return configTree

    moonfinSettings = findSettingsSectionByTitle(configTree, "Moonfin Settings")
    pluginRootSection = findSettingsSectionByTitle(configTree, "Moonfin Plugin")
    playback = findSettingsSectionByTitle(configTree, "Playback")
    rememberMe = findSettingsSectionByTitle(configTree, "Remember Me?")
    userInterface = findSettingsSectionByTitle(configTree, "User Interface")
    secret = findSettingsSectionByTitle(configTree, "Secret")

    navigationBar = findSettingsChildByTitle(moonfinSettings, "Navigation Bar")
    homeScreen = findSettingsChildByTitle(moonfinSettings, "Home Screen")
    featuredMediaBar = findSettingsChildByTitle(moonfinSettings, "Featured Media Bar")
    themeMusic = findSettingsChildByTitle(moonfinSettings, "Theme Music")
    shuffle = findSettingsChildByTitle(moonfinSettings, "Shuffle")
    visualEffects = findSettingsChildByTitle(moonfinSettings, "Visual Effects")
    supportMoonfin = findSettingsChildByTitle(moonfinSettings, "Support Moonfin")

    colors = findSettingsChildByTitle(userInterface, "Colors")
    general = findSettingsChildByTitle(userInterface, "General")
    homeRows = findSettingsChildByTitle(userInterface, "Home Rows")

    enablePlugin = findSettingsChildByTitle(pluginRootSection, "Enable Plugin")
    pluginSettingsSync = findSettingsChildByTitle(pluginRootSection, "Settings Sync")
    pluginHss = findSettingsChildByTitle(pluginRootSection, "Home Screen Sections")
    pluginKefinTweaks = findSettingsChildByTitle(pluginRootSection, "KefinTweaks")
    mdblist = findSettingsChildByTitle(pluginRootSection, "MDBList Ratings")
    tmdb = findSettingsChildByTitle(pluginRootSection, "TMDB")
    jellyseerr = findSettingsChildByTitle(pluginRootSection, "Seerr")
    if not isValid(jellyseerr)
        jellyseerr = findSettingsChildByTitle(pluginRootSection, "Jellyseerr")
    end if

    reordered = []

    accountChildren = []
    if isValid(rememberMe)
        rememberMe.title = "Auto Sign In"
        rememberMe.description = "Automatically sign in with the last logged-in user on app start."
        accountChildren.push(rememberMe)
    end if
    if accountChildren.count() > 0
        reordered.push({
            title: "Account & Security",
            description: "Automatic sign-in preferences.",
            children: accountChildren
        })
    end if

    personalizationChildren = []
    pushSettingIfValid(personalizationChildren, navigationBar)
    pushSettingIfValid(personalizationChildren, homeScreen)
    pushSettingIfValid(personalizationChildren, colors)
    pushSettingIfValid(personalizationChildren, general)
    pushSettingIfValid(personalizationChildren, homeRows)
    if personalizationChildren.count() > 0
        reordered.push({
            title: "Personalization",
            description: "Navigation, home screen, colors, and interface preferences.",
            children: personalizationChildren
        })
    end if

    dynamicChildren = []
    pushSettingIfValid(dynamicChildren, featuredMediaBar)
    pushSettingIfValid(dynamicChildren, visualEffects)
    if dynamicChildren.count() > 0
        reordered.push({
            title: "Dynamic Content",
            description: "Media Bar and visual overlays",
            children: dynamicChildren
        })
    end if

    if isValid(playback)
        playback.title = "Playback"
        playback.description = "Audio/video playback, subtitles, bitrate, and compatibility controls."
        reordered.push(playback)
    end if

    pluginChildren = []
    pushSettingIfValid(pluginChildren, enablePlugin)
    pushSettingIfValid(pluginChildren, pluginSettingsSync)
    pushSettingIfValid(pluginChildren, pluginHss)
    pushSettingIfValid(pluginChildren, pluginKefinTweaks)

    integrationsChildren = []
    if pluginChildren.count() > 0
        integrationsChildren.push({
            title: "Plugin",
            description: "Plugin connectivity and settings sync.",
            children: pluginChildren
        })
    end if
    pushSettingIfValid(integrationsChildren, mdblist)
    pushSettingIfValid(integrationsChildren, tmdb)
    pushSettingIfValid(integrationsChildren, jellyseerr)
    if integrationsChildren.count() > 0
        reordered.push({
            title: "Integrations",
            description: "Plugin, Seerr, and ratings integrations.",
            children: integrationsChildren
        })
    end if

    aboutChildren = []
    pushSettingIfValid(aboutChildren, supportMoonfin)
    if aboutChildren.count() > 0
        reordered.push({
            title: "About",
            description: "Support Moonfin and project information.",
            children: aboutChildren
        })
    end if

    advancedChildren = []
    pushSettingIfValid(advancedChildren, themeMusic)
    pushSettingIfValid(advancedChildren, shuffle)
    pushSettingIfValid(advancedChildren, secret)
    if advancedChildren.count() > 0
        reordered.push({
            title: "Advanced",
            description: "Theme music, shuffle, and advanced Roku options.",
            children: advancedChildren
        })
    end if

    additionalChildren = []

    moonfinMappedTitles = ["Navigation Bar", "Home Screen", "Featured Media Bar", "Theme Music", "Shuffle", "Visual Effects", "Support Moonfin"]
    pushUnmappedChildrenByTitle(additionalChildren, moonfinSettings, moonfinMappedTitles)

    pluginMappedTitles = ["Enable Plugin", "Settings Sync", "Home Screen Sections", "KefinTweaks", "MDBList Ratings", "TMDB", "Seerr", "Jellyseerr"]
    pushUnmappedChildrenByTitle(additionalChildren, pluginRootSection, pluginMappedTitles)

    userInterfaceMappedTitles = ["Colors", "General", "Home Rows"]
    pushUnmappedChildrenByTitle(additionalChildren, userInterface, userInterfaceMappedTitles)

    if additionalChildren.count() > 0
        reordered.push({
            title: "Additional Settings",
            description: "Settings that are not yet grouped in the new layout.",
            children: additionalChildren
        })
    end if

    knownRootTitles = ["Moonfin Settings", "Moonfin Plugin", "Playback", "Remember Me?", "User Interface", "Secret"]
    for each rootSection in configTree
        rootTitle = chainLookupReturn(rootSection, "title", "")
        if not isValidAndNotEmpty(rootTitle) then continue for
        if titleExistsInList(knownRootTitles, rootTitle) then continue for
        reordered.push(rootSection)
    end for

    if reordered.count() = 0
        return configTree
    end if

    return reordered
end function

sub LoadMenu(configSection, appendPath = true as boolean)
    updateHssSettingGate()
    updateKtSettingGate()

    if configSection.children = invalid
        ' Load parent menu
        m.userLocation.pop()
        configSection = m.userLocation.peek()
    else
        settingsArray = []

        for each item in configSection.children
            settingsArray.push(item)
        end for

        configSection.children = settingsArray

        if appendPath
            if m.userLocation.Count() > 0 then m.userLocation.peek().selectedIndex = m.settingsMenu.itemFocused
            m.userLocation.push(configSection)
        end if
    end if

    result = CreateObject("roSGNode", "ContentNode")
    m.settingsMenu.content = result

    ' Create a mapping array to track which config items are visible
    m.visibleItemsMap = []

    for each item in configSection.children
        if isValid(item.visible)
            if not item.visible
                if not m.showSecretMenu
                    continue for
                end if
            end if
        end if

        ' Add to visible items mapping
        m.visibleItemsMap.push(item)

        listItem = result.CreateChild("ContentNode")
        listItem.title = tr(item.title)
        listItem.Description = tr(item.description)
        listItem.addFields({ currentValue: getSettingCurrentValueLabel(item) })
        listItem.id = item.id
    end for

    if configSection.selectedIndex <> invalid and configSection.selectedIndex > -1
        m.settingsMenu.jumpToItem = configSection.selectedIndex
    end if

    ' Set Path display
    if appendPath
        m.path.text = tr("Settings")
        for each level in m.userLocation
            if level.title <> invalid then m.path.text += " / " + tr(level.title)
        end for
    end if
end sub

sub settingFocused()
    selectedSetting = getFocusedSetting()
    if not isValid(selectedSetting) then return

    if isValid(selectedSetting.Description)
        m.settingDesc.text = tr(selectedSetting.Description)
    else
        m.settingDesc.text = ""
    end if

    hideEditingControls()
end sub

sub settingSelected()
    selectedItem = getFocusedSetting()

    if not isValid(selectedItem) then return

    hideEditingControls()

    if isValid(selectedItem.settingName) and selectedItem.settingName = "moonfin.showDonation"
        showDonationDialog()
        return
    end if

    if isValid(selectedItem.settingName) and selectedItem.settingName = "jellyseerr.testConnectionLocal"
        testJellyseerrConnection("local")
        return
    end if

    if isValid(selectedItem.settingName) and selectedItem.settingName = "jellyseerr.testConnection"
        testJellyseerrConnection()
        return
    end if

    if isValid(selectedItem.settingName) and selectedItem.settingName = "jellyseerr.accountSettings"
        PopulateSeerrAccountChildren(selectedItem)
        LoadMenu(selectedItem)
        return
    end if

    if isValid(selectedItem.settingName) and selectedItem.settingName = "jellyseerr.signIn.jellyfin"
        StartSeerrJellyfinSignIn()
        return
    end if

    if isValid(selectedItem.settingName) and selectedItem.settingName = "jellyseerr.signIn.local"
        StartSeerrLocalSignIn()
        return
    end if

    if isValid(selectedItem.settingName) and selectedItem.settingName = "jellyseerr.signOut"
        PerformSeerrSignOut()
        return
    end if

    if isValid(selectedItem.settingName) and selectedItem.settingName = "jellyseerr.accountStatus"
        return ' read-only status row
    end if

    if isValid(selectedItem.settingName) and isMediaBarMultiSelectSetting(selectedItem.settingName)
        m.settingDesc.visible = false
        loadMediaBarPickerOptions(selectedItem)
        return
    end if

    if isValid(selectedItem.settingName) and isPluginRowsManagerSetting(selectedItem.settingName)
        m.settingDesc.visible = false
        openPluginRowsManager(selectedItem)
        return
    end if

    if selectedItem.type <> invalid
        if isValid(selectedItem.Description)
            m.settingDesc.text = tr(selectedItem.Description)
        else
            m.settingDesc.text = ""
        end if

        if isStringEqual(selectedItem.settingName, "jellyseerr.testConnection")
            authStatus = GetJellyseerrAuthStatus()
            m.settingDesc.text = tr(selectedItem.Description) + Chr(10) + Chr(10) + authStatus
        end if

        m.settingDesc.visible = true

        if isStringEqual(selectedItem.type, SettingType.BOOL)
            m.boolSetting.visible = true

            selectedValue = get_user_setting(selectedItem.settingName)
            if not isValid(selectedValue) and isValid(m.global.session.user.settings[selectedItem.settingName])
                selectedValue = m.global.session.user.settings[selectedItem.settingName]
            end if

            valueString = LCase(dynamicToDisplayString(selectedValue))
            if isStringEqual(valueString, "true")
                m.boolSetting.checkedItem = 1
            else
                m.boolSetting.checkedItem = 0
            end if

            m.boolSetting.setFocus(true)
            return
        end if

        if isStringEqual(selectedItem.type, SettingType.COLORGRID)
            m.colorgrid.setting = selectedItem
            m.colorgrid.visible = true
            m.colorgrid.setFocus(true)
            return
        end if

        if isStringEqual(selectedItem.type, SettingType.integer)
            integerValue = dynamicToDisplayString(get_user_setting(selectedItem.settingName))
            if not isValidAndNotEmpty(integerValue)
                integerValue = dynamicToDisplayString(m.global.session.user.settings[selectedItem.settingName])
            end if
            if isValidAndNotEmpty(integerValue)
                m.integerSetting.text = integerValue
            end if

            m.integerSetting.visible = true
            m.integerSetting.setFocus(true)
            return
        end if

        if isStringEqual(selectedItem.type, SettingType.RADIO)
            if isStringEqual(selectedItem.settingName, "playback.media.forceTranscode")
                originalSelectedValue = m.global.session.user.settings[selectedItem.settingName]

                if isStringEqual(type(originalSelectedValue), "roBoolean") or isStringEqual(type(originalSelectedValue), "Boolean")
                    convertedValue = originalSelectedValue ? PlaybackMethod.FORCETRANSCODEALLOWREMUX : selectedItem.default
                    set_user_setting(selectedItem.settingName, convertedValue)
                end if
            end if

            selectedValue = m.global.session.user.settings[selectedItem.settingName]
            radioOptions = selectedItem.options

            if Left(chainLookupReturn(selectedItem, "settingName", ""), 17) = "homeScreenSection"
                filteredOptions = []
                for each option in selectedItem.options
                    optionId = chainLookupReturn(option, "id", "")
                    if isStringEqual(optionId, "hss_all") and not isHssPluginDetected()
                        continue for
                    end if
                    if isStringEqual(optionId, "kt_all") and not isKtPluginDetected()
                        continue for
                    end if
                    filteredOptions.push(option)
                end for
                radioOptions = filteredOptions
            end if

            radioContent = CreateObject("roSGNode", "ContentNode")

            selectedIndex = 0
            itemIndex = 0
            for each item in radioOptions
                listItem = radioContent.CreateChild("ContentNode")
                listItem.title = tr(item.title)
                listItem.id = item.id
                if selectedValue = item.id
                    selectedIndex = itemIndex
                end if
                itemIndex++
            end for

            m.radioSetting.content = radioContent
            m.radioSetting.visible = true
            m.radioSetting.checkedItem = selectedIndex
            m.radioSetting.setFocus(true)
            return
        end if

        if isStringEqual(selectedItem.type, SettingType.SLIDER)
            sliderOptions = []
            for each item in selectedItem.options
                sliderOptions.push(item.value)
            end for

            m.slider.options = sliderOptions
            m.slider.value = m.global.session.user.settings[selectedItem.settingName]
            m.slider.visible = true
            m.slider.setFocus(true)
            return
        end if

        if isStringEqual(selectedItem.type, SettingType.STRING)
            m.settingDesc.visible = false
            showStringInputDialog(selectedItem)
            return
        end if
    else if selectedItem.children <> invalid and selectedItem.children.Count() > 0 ' Show sub menu
        LoadMenu(selectedItem)
        m.settingsMenu.setFocus(true)
    else
        return
    end if
end sub

sub refreshMenu()
    selectedItem = m.userLocation[m.userLocation.count() - 1]
    LoadMenu(selectedItem, false)
end sub

sub boolSettingChanged()
    if m.boolSetting.focusedChild = invalid then return
    selectedSetting = getFocusedSetting()
    if not isValid(selectedSetting) then return

    if selectedSetting.settingName = "plugin.hss.enabled" and m.boolSetting.checkedItem = 1 and not isHssPluginDetected()
        ShowToast("Home Screen Sections plugin was not detected on this server.", "error")
        setUserBoolSetting("plugin.hss.enabled", false)
        refreshCurrentItemValue(selectedSetting)
        hideEditingControls()
        m.settingsMenu.setFocus(true)
        return
    end if

    if selectedSetting.settingName = "plugin.kefintweaks.enabled" and m.boolSetting.checkedItem = 1 and not isKtPluginDetected()
        ShowToast("KefinTweaks plugin was not detected on this server.", "error")
        setUserBoolSetting("plugin.kefintweaks.enabled", false)
        refreshCurrentItemValue(selectedSetting)
        hideEditingControls()
        m.settingsMenu.setFocus(true)
        return
    end if

    if m.boolSetting.checkedItem = 1
        session.user.settings.Save(selectedSetting.settingName, "true")
        if Left(selectedSetting.settingName, 7) = "global."
            ' global user setting
            ' save to main registry block
            set_setting(selectedSetting.settingName, "true")
            ' setting specific triggers
            if selectedSetting.settingName = "global.rememberme"
                set_setting("active_user", m.global.session.user.id)
            end if
        else
            ' regular user setting
            ' save to user specific registry block
            set_user_setting(selectedSetting.settingName, "true")
            if selectedSetting.settingName = "jellyseerr.blockNsfw"
                SetJellyseerrBlockNsfw(true)
            end if
            if selectedSetting.settingName = "plugin.enabled"
                testPluginConnection()
            end if
        end if
        syncSettingToServer(selectedSetting.settingName, "true")
    else
        session.user.settings.Save(selectedSetting.settingName, "false")
        if Left(selectedSetting.settingName, 7) = "global."
            ' global user setting
            ' save to main registry block
            set_setting(selectedSetting.settingName, "false")
            ' setting specific triggers
            if selectedSetting.settingName = "global.rememberme"
                unset_setting("active_user")
            end if
        else
            ' regular user setting
            ' save to user specific registry block
            set_user_setting(selectedSetting.settingName, "false")
            if selectedSetting.settingName = "jellyseerr.blockNsfw"
                SetJellyseerrBlockNsfw(false)
            end if
        end if
        syncSettingToServer(selectedSetting.settingName, "false")
    end if

    refreshCurrentItemValue(selectedSetting)
    hideEditingControls()
    m.settingsMenu.setFocus(true)

    if selectedSetting.settingName = "plugin.enabled"
        refreshHssPluginDetection()
        refreshKtPluginDetection()
        if m.userLocation.Count() > 0
            RefreshCurrentMenu()
        end if
    else if selectedSetting.settingName = "homeRows.useServerConfig"
        updateHssSettingGate()
        updateKtSettingGate()
        if m.userLocation.Count() > 0
            RefreshCurrentMenu()
        end if
    end if
end sub

sub radioSettingChanged()
    if m.radioSetting.focusedChild = invalid then return
    selectedSetting = getFocusedSetting()
    if not isValid(selectedSetting) then return

    selectedValue = m.radioSetting.content.getChild(m.radioSetting.checkedItem).id
    set_user_setting(selectedSetting.settingName, selectedValue)

    if isStringEqual(selectedSetting.settingName, "ui.overlayOpacity") or isStringEqual(selectedSetting.settingName, "ui.overlayColor") or isStringEqual(selectedSetting.settingName, "navbar.opacity") or isStringEqual(selectedSetting.settingName, "navbar.color")
        if isValid(m.global)
            m.global.overlaySettingsChanged = m.global.overlaySettingsChanged + 1
        end if
    end if

    if isStringEqual(selectedSetting.settingName, "navbar.position")
        selectedPosition = m.radioSetting.content.getChild(m.radioSetting.checkedItem).id
        scene = m.top.getScene()
        if isValid(scene)
            overhang = scene.findNode("overhang")
            sidebar = scene.findNode("sidebar")
            if isStringEqual(selectedPosition, "left")
                if isValid(overhang)
                    overhang.visible = false
                    overhang.isVisible = false
                end if
                if isValid(sidebar)
                    sidebar.visible = true
                    sidebar.callFunc("loadLibraries")
                end if
            else
                if isValid(sidebar)
                    sidebar.visible = false
                end if
                if isValid(overhang)
                    overhang.visible = true
                    overhang.isVisible = true
                    overhang.callFunc("loadLibraries")
                end if
            end if
            m.global.sceneManager.callFunc("refreshNavReference")
        end if
    end if

    if isStringEqual(selectedSetting.settingName, "playback.media.forceTranscode")
        if isStringEqual(m.radioSetting.content.getChild(m.radioSetting.checkedItem).id, PlaybackMethod.PLAYNORMALLY)
            m.global.queueManager.callFunc("setForceTranscode", PlaybackMethod.PLAYNORMALLY)
        end if
    end if

    syncSettingToServer(selectedSetting.settingName, selectedValue)

    if Left(chainLookupReturn(selectedSetting, "settingName", ""), 17) = "homeScreenSection"
        syncHomeRowsContractToServer()
    end if

    refreshCurrentItemValue(selectedSetting)
    hideEditingControls()
    m.settingsMenu.setFocus(true)
end sub

' JFScreen hook called when screen is shown
sub OnScreenShown(_isReturning = false as boolean)
    ' Restore focus to settings menu when returning to this screen
    if isValid(m.settingsMenu)
        m.settingsMenu.setFocus(true)
    end if
end sub

' JFScreen hook that gets ran as needed.
' Assumes settings were changed and they affect the device profile.
' Posts a new device profile to the server using the task thread
sub OnScreenHidden()
    m.postTask.arrayData = getDeviceCapabilities()
    m.postTask.apiUrl = "/Sessions/Capabilities/Full"
    m.postTask.control = "RUN"
    m.postTask.observeField("responseCode", "postFinished")
end sub

' Triggered by m.postTask after completing a post.
' Empty the task data when finished.
sub postFinished()
    m.postTask.unobserveField("responseCode")
    m.postTask.callFunc("empty")
end sub

' Returns true if any of the data entry forms are in focus
function isFormInFocus() as boolean
    if m.radioSetting.hasFocus() or m.boolSetting.hasFocus() or m.integerSetting.hasFocus() or m.colorgrid.hasFocus() or m.slider.hasFocus()
        return true
    end if
    return false
end function

sub checkMagicKeyPressSequence(key as string)
    m.keypressTimer.control = "stop"
    m.keypressTimer.control = "start"

    m.keypresses.push(key)

    if m.keypresses.count() < m.magicKeyPressSequence.count() then return

    for i = 0 to m.keypresses.count()
        if m.keypresses[i] <> m.magicKeyPressSequence[i] then return
    end for

    m.showSecretMenu = true
    LoadMenu({ children: m.configTree })
end sub

function onKeyEvent(key as string, press as boolean) as boolean
    if not press then return false

    checkMagicKeyPressSequence(key)

    if key = "back" or key = "left"
        if m.settingsMenu.focusedChild <> invalid and m.userLocation.Count() > 1
            LoadMenu({})
            return true
        end if

        if isFormInFocus()
            hideEditingControls()
            m.settingsMenu.setFocus(true)
            return true
        end if

        if m.settingsMenu.focusedChild <> invalid
            dismissPanel()
            return true
        end if

        if isValid(m.version) and m.version.hasFocus()
            dismissPanel()
            return true
        end if
    end if

    if key = "options"
        dismissPanel()
        return true
    end if

    if isValid(m.version)
        if isStringEqual(key, KeyCode.DOWN)
            if m.settingsMenu.hasFocus()
                m.version.setfocus(true)
                m.version.text = `${LCase(m.global.app.name)} ${m.global.app.version} - <b>${tr("What's New")}?</b>`
                return true
            end if
        end if

        if m.version.hasFocus()
            if isStringEqual(key, KeyCode.UP)
                m.settingsMenu.setfocus(true)
                m.version.text = `${LCase(m.global.app.name)} ${m.global.app.version} - ${tr("What's New")}?`
                return true
            end if

            if isStringEqual(key, KeyCode.OK)
                m.global.sceneManager.callFunc("whatsNewDialog")
                return true
            end if
            return false
        end if
    end if

    if key = "right"
        settingSelected()
    end if

    return false
end function

' Handle authentication modal closed
sub onAuthModalClosed(_obj as object)
    ' Close the dialog
    m.top.getScene().dialog.close = true
    m.settingsMenu.setFocus(true)
end sub

' Show donation dialog
sub showDonationDialog()
    ' Create the donation dialog
    dialog = createObject("roSGNode", "DonationDialog")
    dialog.observeField("wasClosed", "onDonationDialogClosed")

    ' Add dialog to the scene
    m.top.getScene().appendChild(dialog)
    m.donationDialog = dialog
end sub

' Handle donation dialog closed
sub onDonationDialogClosed(_obj as object)
    ' Remove the dialog from the scene
    if isValid(m.donationDialog)
        m.top.getScene().removeChild(m.donationDialog)
        m.donationDialog = invalid
    end if

    ' Return focus to settings menu
    m.settingsMenu.setFocus(true)
end sub

' ============================================
' Jellyseerr Permissions
' ============================================

' Fetch user permissions from Jellyseerr /auth/me endpoint
sub FetchJellyseerrUserPermissions(userId as string)
    m.permissionsTask = CreateObject("roSGNode", "JellyseerrAPITask")
    m.permissionsTask.addFields({ targetUserId: userId })
    m.permissionsTask.request = {
        method: "GET",
        endpoint: "/api/v1/auth/me"
    }
    m.permissionsTask.observeField("response", "onPermissionsResponse")
    m.permissionsTask.control = "RUN"
end sub

sub onPermissionsResponse(event as object)
    response = event.getData()
    task = event.getRoSGNode()
    userId = task.targetUserId


    if response.success and response.data <> invalid
        permissions = 0
        if response.data.permissions <> invalid
            permissions = response.data.permissions
        end if
        SetJellyseerrUserPermissions(userId, permissions)
    else
    end if
end sub
